#ifdef ___TRAIT_COUNT_ACTIVE
// ═══════════════════════════════════════════════════════════════════════════════
// METHOD COUNTING LOOP BODY
//
// Counts methods in a trait by iterating until sentinel. Saves count to
// ___TRAIT_MCOUNT_<T2><T1> via the ops block.
// ═══════════════════════════════════════════════════════════════════════════════
#if !___TRAIT_SD_IS_STOP(___TRAIT_SD_PASS, Impl)

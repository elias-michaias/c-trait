    glue5(___TRAIT_SDFL_, 0, _, 0, ___TRAIT_NARG(__VA_ARGS__)),                    \
    Type, Ret, Name, ##__VA_ARGS__)
#define ___TRAIT_ACT_SDFL_DEFAULT_1(Type, Ret, Name, ...)                        \
